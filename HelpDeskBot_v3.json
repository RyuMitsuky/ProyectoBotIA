    {
      "parameters": {
        "jsCode": "const item = $input.item.json;\nconst buildData = $('Build Prompt').item.json;\n\nconst raw =\n  item.content?.parts?.[0]?.text ||\n  item.candidates?.[0]?.content?.parts?.[0]?.text ||\n  item.text ||\n  item.output ||\n  '';\n\nlet parsed = {};\n\ntry {\n  const clean = raw\n    .replace(/```json/gi, '')\n    .replace(/```/g, '')\n    .trim();\n\n  parsed = JSON.parse(clean);\n} catch (e) {\n  parsed = {\n    msg: 'ERROR PARSE',\n    pantalla: 'menu',\n    accion: 'ninguna',\n    datos: {},\n    ticket: null\n  };\n}\n\nreturn [{\n  json: {\n    msg: parsed.msg,\n    pantalla: parsed.pantalla,\n    accion: parsed.accion,\n    datos: parsed.datos || {},\n    ticket: parsed.ticket || null,\n    telegram_user_id: buildData.telegram_user_id,\n    telegram_chat_id: buildData.telegram_chat_id,\n    telegram_username: buildData.telegram_username,\n    user_first_name: buildData.user_first_name\n  }\n}];"
      },
